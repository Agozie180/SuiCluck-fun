# Copy this file to `.env.local` and fill in the values for local development

# Enoki public API key (obtain from https://portal.enoki.mystenlabs.com/)
NEXT_PUBLIC_ENOKI_API_KEY=your_enoki_public_api_key_here

# Optional: package id used by SuiCluck demo (replace with your own package id if available)
NEXT_PUBLIC_SUICLUCK_PACKAGE_ID=0xYOUR_PACKAGE_ID_HERE

# Optional runtime flags
# Set to 'development' locally if needed
NEXT_PUBLIC_NODE_ENV=development
